# Keep this key server-side. Never prefix it with VITE_ or commit .env.local.
OPENAI_API_KEY=replace-with-your-openai-key

# Optional override. The default is the current flagship model.
OPENAI_OBJECT_MODEL=gpt-5.6-sol

# Optional quality-neutral latency upgrade. Priority uses premium API pricing.
OPENAI_OBJECT_SERVICE_TIER=auto
